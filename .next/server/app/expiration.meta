{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/expiration/layout,_N_T_/expiration/page,_N_T_/expiration"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/expiration/__PAGE__",
    "/expiration",
    "/_index",
    "/_head"
  ]
}